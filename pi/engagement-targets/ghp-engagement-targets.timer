[Unit]
Description=Generate engagement-target file daily at 06:15 ET (before daily-loop summary)

[Timer]
# 06:15 America/New_York. Pi clock is UTC so use OnCalendar with Persistent.
# DST shifts: in EDT (Mar-Nov) this fires at 10:15 UTC. In EST it fires at 11:15 UTC.
# Using America/New_York TZ in OnCalendar (systemd >= 230) avoids the DST math.
OnCalendar=*-*-* 06:15:00 America/New_York
Persistent=true

[Install]
WantedBy=timers.target
