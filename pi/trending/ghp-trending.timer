[Unit]
Description=GHP Daily Trending Roundup — fire once per morning

[Timer]
# 11:10 UTC = ~7:10 AM ET. Fresh post lands before the US morning. Best-seller
# charts update hourly, so exact timing is not critical.
OnCalendar=*-*-* 11:10:00
RandomizedDelaySec=600
Persistent=true

[Install]
WantedBy=timers.target
